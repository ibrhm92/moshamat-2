rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow read access to all collections (for demo purposes)
    // In production, you might want to restrict this more
    match /{document=**} {
      allow read: if true;
      allow write: if true;
    }
    
    // More specific rules for production (uncomment and customize as needed)
